# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Usado por `bun run db:types` (genera src/types/database.ts).
# OJO: ese script trunca database.ts si PROJECT_ID está vacío.
PROJECT_ID=

# === OpenAI (categorización de items de factura) ===
OPENAI_API_KEY=
# Modelo para categorizar items (opcional, default gpt-4o-mini)
OPENAI_CATEGORIZE_MODEL=gpt-4o-mini

# === Motor de facturas DIAN (proxy CUFE) ===
# Endpoint que procesa el CUFE y devuelve items estructurados.
FACTURA_DIAN_URL=https://factura-dian.vercel.app
# Método de extracción: python (default) | openai
FACTURA_DIAN_METHOD=python
