# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Usado por `bun run db:types` (genera src/types/database.ts).
# OJO: ese script trunca database.ts si PROJECT_ID está vacío.
PROJECT_ID=

# === Categorización de items con MiniMax (endpoint Anthropic-compatible) ===
# Coding Plan key (prefijo sk-cp-). Si está vacío, los items caen a 'OTROS'.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
# Modelo (default MiniMax-M2.7; existe MiniMax-M2.7-highspeed)
CATEGORIZE_MODEL=MiniMax-M2.7

# === Motor de facturas DIAN (proxy CUFE) ===
# Endpoint que procesa el CUFE y devuelve items estructurados.
FACTURA_DIAN_URL=https://factura-dian.vercel.app
# Método de extracción: python (default) | openai
FACTURA_DIAN_METHOD=python
